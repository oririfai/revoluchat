# PostgreSQL — revoluchat database (conversations, messages, dll)
DATABASE_URL=ecto://postgres:postgres@localhost/revoluchat_dev

# Phoenix
SECRET_KEY_BASE=secret
PHX_HOST=localhost
PORT=4000

# Object Storage (Modes: minio, cloudflareR2, cloudinary)
STORAGE_ADAPTOR_MODE=cloudflareR2

# --- Mode: minio ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
STORAGE_BUCKET=revoluchat
MINIO_HOST=localhost
MINIO_PUBLIC_HOST=localhost
MINIO_PORT=9000

# --- Mode: cloudflareR2 ---
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_ACCOUNT_ID=xxx
R2_BUCKET=revoluchat
R2_PUBLIC_DOMAIN=https://chat-assets.example.com

# --- Mode: cloudinary ---
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=1234...
# CLOUDINARY_API_SECRET=secret

# Push Notifications
FCM_SERVER_KEY=<dari Firebase Console>

# External User Service (gRPC)
USER_SERVICE_GRPC_ENDPOINT=host.docker.internal:50051

# JWT Verification

JWKS_URL=http://host.docker.internal:8089/jwks


# CORS
CORS_ALLOWED_ORIGINS=*

# LiveKit Configuration
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
