# .env.example — commit file ini ke repo
# Salin ke .env dan isi nilainya. Jangan commit .env!

# PostgreSQL — revoluchat database (conversations, messages, dll)
DATABASE_URL=ecto://postgres:postgres@localhost/revoluchat_dev

# Phoenix
SECRET_KEY_BASE=secret
PHX_HOST=localhost
PORT=4000

# RSA Public Key — dari user service (untuk verify JWT RS256)
# Letakkan file PEM di: priv/keys/public_key.pem

# MinIO / AWS S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
MINIO_HOST=localhost
MINIO_PORT=9000
STORAGE_BUCKET=revochat

# Push Notifications
FCM_SERVER_KEY=<dari Firebase Console>
