# PostgreSQL — revoluchat database (conversations, messages, dll)
DATABASE_URL=ecto://postgres:postgres@localhost/revoluchat_dev

# Phoenix
SECRET_KEY_BASE=secret
PHX_HOST=localhost
PORT=4000

# Object Storage (MinIO / AWS S3 / Cloudinary)
# Options: "s3" or "cloudinary"
STORAGE_PROVIDER=s3

# S3 / MinIO Settings (if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
MINIO_HOST=localhost
MINIO_PORT=9000
STORAGE_BUCKET=revochat

# Cloudinary Settings (if STORAGE_PROVIDER=cloudinary)
# You can use the URL or individual components
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=1234...
CLOUDINARY_API_SECRET=secret

# Push Notifications
FCM_SERVER_KEY=<dari Firebase Console>

# External User Service (gRPC)
USER_SERVICE_GRPC_ENDPOINT=host.docker.internal:50051

# JWT Verification

JWKS_URL=http://host.docker.internal:8089/jwks


# CORS
CORS_ALLOWED_ORIGINS=*

# WebRTC — ICE Servers (JSON List)
# Example with TURN:
# ICE_SERVERS='[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:my-turn-server.com","username":"secret-user","credential":"secret-password"}]'
ICE_SERVERS='[{"urls":"stun:stun.l.google.com:19302"}]'