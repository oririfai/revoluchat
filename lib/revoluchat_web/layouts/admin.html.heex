<div class="flex min-h-full">
  <.sidebar active_tab={@active_tab} admin_name="Admin" collapsed={@sidebar_collapsed} />

  <!-- Main Content -->
  <div class={[
    "flex flex-col flex-1 transition-all duration-300 ease-in-out",
    if(@sidebar_collapsed, do: "lg:pl-20", else: "lg:pl-64")
  ]}>
    <.mobile_header />

    <main class="flex-1 pb-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <%= @inner_content %>
      </div>
    </main>
  </div>
</div>
